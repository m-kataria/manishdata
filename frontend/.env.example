# URL of the Flask backend that the SvelteKit server talks to.
# Locally: http://localhost:5000
# Railway: https://<your-backend-service>.up.railway.app
BACKEND_URL=http://localhost:5000

# Origin the SvelteKit server is accessible at. Used to set the right cookie domain.
# Locally: http://localhost:5173
# Railway: https://<your-frontend-service>.up.railway.app
ORIGIN=http://localhost:5173
