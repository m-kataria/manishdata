# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql://user:pass@localhost:5432/nerval_ops
FRONTEND_ORIGIN=http://localhost:5173

# Business Central — OAuth client credentials (S2S)
BC_TENANT_ID=
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_ENVIRONMENT=Production
BC_COMPANY_ID=

# Mock mode: 'auto' (mock when creds are placeholders), 'on' (always mock), 'off' (always real)
BC_MOCK_MODE=auto

# Salesforce — username + password + security token
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login

# Initial admin user created by scripts/init_db.py (only used on first run)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
